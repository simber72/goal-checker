_SET ?I 'alice'
_SET ?B 'bob'
_SET ?A 'charlie'
_SET ?agreesText1 (generateNumberText1 | inv_checkText1 | eq_checkText1)
_SET ?generatesText1 (generateNumberText1)
_SET ?Text1 'X0','X4','X8','X12','X16','X20','X24','X28','X32','X36'
_SET ?can_recover (inv_check | eq_check)
_SET ?can_read (inv_check)
;GOAL auth:[?Text1],[?B,?A]

;AUTH_VIOLATION
G z.( !("(z)z[active]==?A" & ?agreesText1) |! X F y.("(y)y[active]==?B" & ?can_recover & ("(z,y)z[mess]==y[mess]")))


_WRITE
_BYE
